# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
SERVER_PORT=9001
NODE_ENV=development

# Database Connection
# Option 1: MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/project_management

# Option 2: Local MongoDB
MONGODB_PATH=mongodb://localhost:27017/project_management

# JWT Secret (Change this to a strong random string in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# CORS Configuration
# Set to the exact URL where your frontend runs
CORS_ORIGIN=http://localhost:3000
